        self.snapshot_every = 50
        self.current_batch_idx = 0

    def validate_parameters(self):
        """Валидация всех параметров перед запуском"""
        logger.info("=== ВАЛИДАЦИЯ ПАРАМЕТРОВ ===")

        # Проверка баланса cost matrix
