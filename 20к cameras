        logger.info(f"Overall time: {total_time:.2f}с")
        logger.info(f"QUBO time: {total_qubo_time:.2f}с ({total_qubo_time / total_time * 100:.1f}%)")
        logger.info(f"Annealing time : {total_quantum_time:.2f}с ({quantum_efficiency:.1f}%)")

    def run_optimized_comparison(self):
        """Оптимизированное сравнение с УМНЫМ таймаутом"""
        logger.info("=== Optimized Comparison ===")

