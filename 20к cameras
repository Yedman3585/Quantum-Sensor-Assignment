    def _print_optimized_results(self, results):
        print("\n" + "=" * 100)
        print("==  RESULTS  ==")
        print("=" * 100)
        print(
            f"{'Method':<20} {'Times (s)':<12} {'Target':<15} {'Cameras':<12} {'Efficiency. (%)':<12} {'Improvement.'}")
